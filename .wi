webinfo
fi
if [ $zz = 10 ]
then
clear
toilet -f smmono12 --gay "Reverseip"
sleep 2
clear
echo $'\e[33m'" "
curl https://api.hackertarget.com/reverseip/?q=$xx
echo " "
toilet -f smmono12 --gay "Done"
webinfo
